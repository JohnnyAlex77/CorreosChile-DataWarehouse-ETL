================================================================================
CONSULTAS ANALITICAS DE EJEMPLO
================================================================================

-- Top 5 clientes por monto de envios
SELECT c.ID_Cliente, c.Tipo_Cliente, SUM(h.Monto_Servicio) AS Total
FROM HechosEnvio h
JOIN DimCliente c ON h.ID_Cliente = c.ID_Cliente
GROUP BY c.ID_Cliente, c.Tipo_Cliente
ORDER BY Total DESC LIMIT 5;

-- Rutas con mayores demoras
SELECT r.Region_Origen, r.Region_Destino, AVG(h.Dias_Transito) AS Promedio
FROM HechosEnvio h
JOIN DimRuta r ON h.ID_Ruta = r.ID_Ruta
WHERE h.Dias_Transito IS NOT NULL
GROUP BY r.Region_Origen, r.Region_Destino
ORDER BY Promedio DESC LIMIT 10;

-- Envios por mes
SELECT YEAR(t.Fecha) AS Anio, MONTH(t.Fecha) AS Mes, COUNT(*) AS Total
FROM HechosEnvio h
JOIN DimTiempo t ON h.ID_Tiempo_Origen = t.ID_Tiempo
GROUP BY YEAR(t.Fecha), MONTH(t.Fecha)
ORDER BY Anio DESC, Mes DESC;

